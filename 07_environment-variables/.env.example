# .env.example — Copy this file to .env and fill in your values.
# コピーして .env にリネームしてから値を入力してください。
# DO NOT commit .env to version control! / .env は Git にコミットしないでください！

# FastAPI app settings / FastAPI アプリ設定
APP_ENV=development
APP_PORT=8000
DEBUG=true

# PostgreSQL settings / PostgreSQL 設定
POSTGRES_USER=ledger_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ledger_dev
POSTGRES_PORT=5432

# Database URL (used by FastAPI / SQLAlchemy)
DATABASE_URL=postgresql://ledger_user:changeme@db:5432/ledger_dev
