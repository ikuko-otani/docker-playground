# DC-01: Compose Quickstart -- environment variable template
# 日本語訳：環境変数のテンプレート（実際の値は .env に記載し .gitignore で除外すること）

# Port exposed on the host machine
# ホスト側に公開するポート番号
APP_PORT=8000

# Flask environment (development / production)
# Flask 実行モード
FLASK_ENV=development

# Flask application entry point
# Flask アプリケーションのエントリポイント
FLASK_APP=app.py
